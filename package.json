{
  "name": "puzzledict",
  "version": "1.0.0",
  "description": "A Chrome extension for translating selected text featuring word roots.",
  "main": "content.js",
  "scripts": {
    "dev": "rollup -c -w --environment NODE_ENV:development",
    "build": "rollup -c --environment NODE_ENV:production",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "log:server": "node scripts/remote-log-server.js",
    "test:dict-api": "node test/dict-api.js"
  },
  "lint-staged": {
    "**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhongyangxun/puzzledict.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/zhongyangxun/puzzledict/issues"
  },
  "homepage": "https://github.com/zhongyangxun/puzzledict#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-copy": "^3.5.0"
  }
}
